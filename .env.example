# Copy to .env and fill in your key if you want Supermemory sync.
# Without this key, Ctrl+Brain still saves locally and agents can use MCP.
# Ctrl+Brain reads this at runtime (env var wins, then .env).
SUPERMEMORY_API_KEY=sm_your_key_here

# Optional: claude or codex. Defaults to claude.
CTRL_BRAIN_DESCRIBE_BACKEND=claude
